PORT=4100
NODE_ENV=staging
DATABASE_URL=postgresql://postgres:postgres@staging-db-host:5432/roomrental
JWT_ACCESS_SECRET=replace_staging_access_secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace_staging_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d
PHONE_OTP_EXPIRES_IN=10m
APP_BASE_URL=https://staging.roomrental.example
EMAIL_VERIFICATION_WEBHOOK_URL=
EMAIL_ALERT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
WHATSAPP_PROVIDER=webhook
WHATSAPP_ALERT_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_API_VERSION=v20.0
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
WORKER_POLL_INTERVAL_MS=5000
IMMERSIVE_JOB_BATCH_SIZE=5
PAYMENT_RECONCILIATION_BATCH_SIZE=10
PAYMENT_RECONCILIATION_CAPTURE_AFTER_MINUTES=2
WORKER_ALERT_WEBHOOK_URL=
WORKER_QUEUE_LAG_ALERT_THRESHOLD_SECONDS=120
WORKER_FAILED_JOBS_ALERT_THRESHOLD=3
WORKER_ALERT_COOLDOWN_MINUTES=10
WORKER_HEARTBEAT_STALE_AFTER_SECONDS=45
CORS_ORIGIN=https://staging.roomrental.example
